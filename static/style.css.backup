}
@keyframes dotPulse{
  0%,100%{transform:scale(1);opacity:1}
  50%{transform:scale(1.2);opacity:0.7}
}
.eligible-dot.yes{
  background:var(--accent);
  box-shadow:0 0 15px var(--accent);
}
.eligible-dot.no{
  background:var(--muted);
  box-shadow:0 0 10px var(--muted);
  animation:none;
