  transition:left 0.5s ease;
}
.donor-mini:hover{
  transform:translateY(-3px) scale(1.02);
  border-color:rgba(255,45,85,.4);
  box-shadow:0 8px 24px rgba(255,45,85,.2);
}
.donor-mini:hover::before{left:100%.pred-card.critical:hover{
