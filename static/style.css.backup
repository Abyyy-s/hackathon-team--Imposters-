lumns:repeat(4,1fr);gap:12px}
.inv-update-card{
  background:linear-gradient(135deg, rgba(14,16,24,.9), rgba(18,20,30,.9));
  border:1px solid var(--border);
  border-radius:16px;padding:16px;text-align:center;
  transition:all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  position:relative;overflow:hidden;
  box-shadow:0 4px 20px rgba(0,0,0,.15);
}
.inv-update-card::before{
  content:'';position:absolute;inset:0;
  background:radial-gradient(circle at center, rgba(255,45,85,.08), transparent);
  opacity:0;transition:opacity 0.3s ease;
}
.inv-update-card:hover{
  transform:translateY(-4px) scale(1.03);
  border-color:rgba(255,45,85,.5);
  box-shadow:0 12px 40px rgba(255,45,85,.3);
}
.inv-update-card:hover::before{opacity:1}
.inv-bt-label{
  font-family:var(--mono);font-size:18px;font-weight:700;
  background:linear-gradient(135deg, var(--red), var(--pink));
  -webkit-background-clip:text;
  background-clip:text;
  -webkit-text-fill-color:transparent;
  margin-bottom:10px;
  animation:colorShift 3s ease-in-out infinite;
}
@keyframes colinear-gradient(135deg, var(--red-d), var(--purple-d));
  border:1px solid rgba(255,45,85,.4);
  border-radius:10px;color:var(--red);
  font-family:var(--font);font-size:11px;font-weight:700;
  padding:5px 14px;cursor:pointer;
  transition:all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  box-shadow:0 2px 10px rgba(255,45,85,.2);
}
.inv-save-btn:hover{
  background:linear-gradient(135deg, rgba(255,45,85,.3), rgba(255,64,129,.3));
  transform:translateY(-2px) scale(1.05);
  box-shadow:0 6px 20px rgba(255,45,85,.4);
olid var(--border);
  border-radius:8px;padding:6px;color:var(--text);font-family:var(--mono);
  font-size:16px;font-weight:700;text-align:center;outline:none;
  transition:border-color .2s;margin-bottom:8px;
}
.inv-inp:focus{border-color:var(--red)}
.inv-save-btn{
  background:var(--red-d);border:1px solid rgba(255,45,85,.3);
  border-radius:8px;color:var(--red);
  font-family:var(--font);font-size:11px;font-weight:700;
  padding:4px 12px;cursor:pointer;transition:all .2s;
}
.inv-save-btn:hover{background:rgba(255,45,85,.2)}

/* ── PREDICTIONS ─────────────────────────────────────── */
.predictions-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px}
.pred-card{
  background:var(--panel);border:1px solid var(--border);
  border-radius:14px;padding:16px;
  transition:transform .2s,border-color .2s;animation:fadeUp .4s ease both;
}
.pred-card:hover{transform:translateY(-3px)}
.pred-card.critical{border-color:rgba(255,45,85,.4);background:linear-gradient(135deg,var(--panel),#12050a)}
.pred-card.high{border-color:rgba(255,160,0,.3)}
.pred-card.medium{border-color:rgba(41,121,255,.3)}
.pred-card.low{border-color:rgba(0,230,118,.3)}
.pred-bt{font-family:var(--mono);font-size:24px;font-weight:700;color:var(--red);margin-bottom:6px}
.pred-risk{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:1px;margin-bottom:8px}
.pred-risk.critical{color:var(--red)}
.pred-risk.high{color:#ffa000}
.pred-risk.medium{color:var(--blue)}
.pred-risk.low{color:var(--accent)}
.pred-days{font-family:var(--mono);font-size:13px;color:var(--muted);margin-bottom:8px}
.pred-rec{font-size:11px;color:var(--muted);line-height:1.5}

/* ── DONOR CARD ──────────────────────────────────────── */
.donor-cards{display:grid;grid-template-columns:repeat(2,1fr);gap:10px}
.donor-mini{
  display:flex;align-items:center;gap:10px;
  background:var(--panel2);border:1px solid var(--border);
  border-radius:10px;padding:10px 12px;
}
.donor-avatar{
  width:36px;height:36px;border-radius:10px;
  background:var(--red-d);border:1px solid rgba(255,45,85,.2);
  display:flex;align-items:center;justify-content:center;
  font-family:var(--mono);font-size:12px;font-weight:700;color:var(--red);flex-shrink:0;
}
.donor-info{flex:1;min-width:0}
.donor-name{font-size:12px;font-weight:700;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.donor-meta{font-size:10px;color:var(--muted);margin-top:2px}
.eligible-dot{
  width:8px;height:8px;border-radius:50%;flex-shrink:0;
}
.eligible-dot.yes{background:var(--accent)}
.eligible-dot.no{background:var(--muted)}

/* ── SHIMMER ─────────────────────────────────────────── */
.shimmer{
  height:160px;border-radius:10px;
  background:linear-gradient(90deg,var(--panel2) 25%,var(--border) 50%,var(--panel2) 75%);
  background-size:400% 100%;
  animation:shimmer 1.5s ease-in-out infinite;
}
@keyframes shimmer{0%{background-position:100% 50%}100%{background-position:0% 50%}}

/* ── RESPONSIVE ──────────────────────────────────────── */
@media(max-width:1100px){
  .gauge-grid{grid-template-columns:repeat(4,1fr)}
  .stat-grid{grid-template-columns:repeat(2,1fr)}
  .predictions-grid{grid-template-columns:repeat(2,1fr)}
  .inv-update-grid{grid-template-columns:repeat(4,1fr)}
}
@media(max-width:768px){
  header{flex-direction:column;height:auto;padding:12px 16px;gap:8px}
  .tabs{flex-wrap:wrap;justify-content:center}
  .two-col{grid-template-columns:1fr}
  .gauge-grid{grid-template-columns:repeat(4,1fr)}
  .inv-update-grid{grid-template-columns:repeat(2,1fr)}
}

/* ── AUTOMATION PANEL ────────────────────────────────── */
.auto-badge{font-family:'JetBrains Mono',monospace;font-size:11px;font-weight:700;letter-spacing:1.5px;padding:5px 12px;border-radius:20px;}
.auto-badge.running{background:rgba(255,45,85,0.15);color:#ff2d55;border:1px solid rgba(255,45,85,0.4);animation:badge-blink 1s ease-in-out infinite;}
.auto-badge.complete{background:rgba(0,230,118,0.12);color:#00e676;border:1px solid rgba(0,230,118,0.3);}
@keyframes badge-blink{0%,100%{opacity:1}50%{opacity:0.4}}
.automation-log{display:flex;flex-direction:column;gap:10px;max-height:320px;overflow-y:auto;}
.auto-row{background:var(--panel2);border:1px solid var(--border);border-radius:10px;padding:12px 14px;animation:rowIn 0.35s cubic-bezier(.16,1,.3,1);}
@keyframes rowIn{from{opacity:0;transform:translateX(-12px)}to{opacity:1;transform:translateX(0)}}
.auto-row-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;}
.auto-donor-info{display:flex;align-items:center;gap:10px;}
.auto-blood-badge{background:rgba(255,45,85,0.15);color:#ff2d55;border:1px solid rgba(255,45,85,0.35);font-family:'JetBrains Mono',monospace;font-size:11px;font-weight:700;padding:2px 8px;border-radius:6px;}
.auto-donor-name{font-weight:700;font-size:14px;color:var(--text);}
.auto-donor-loc{font-size:12px;color:var(--muted);}
.auto-status-pill{font-size:12px;font-weight:600;padding:3px 10px;border-radius:20px;display:flex;align-items:center;gap:5px;}
.auto-status-pill.sending{background:rgba(255,160,0,0.12);color:#ffa000;border:1px solid rgba(255,160,0,0.3);}
.auto-status-pill.sent{background:rgba(0,230,118,0.1);color:#00e676;border:1px solid rgba(0,230,118,0.25);}
.pulse-dot{width:7px;height:7px;background:#ffa000;border-radius:50%;display:inline-block;animation:dot-pulse 0.8s ease-in-out infinite;}
@keyframes dot-pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:0.4;transform:scale(0.7)}}
.auto-sms-preview{font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--muted);background:rgba(0,0,0,0.2);border-left:3px solid rgba(255,45,85,0.4);padding:6px 10px;border-radius:0 6px 6px 0;line-height:1.5;}

/* ── ADVANCED ANIMATIONS & EFFECTS ──────────────────────── */
/* Ripple effect on click */
.ripple{
  position:relative;overflow:hidden;
}
.ripple::after{
  content:'';position:absolute;
  width:100%;height:100%;
  top:50%;left:50%;
  transform:translate(-50%, -50%) scale(0);
  background:radial-gradient(circle, rgba(255,255,255,.3), transparent);
  border-radius:50%;
  opacity:0;
  pointer-events:none;
  transition:transform 0.6s ease, opacity 0.6s ease;
}
.ripple:active::after{
  transform:translate(-50%, -50%) scale(2.5);
  opacity:1;
  transition:0s;
}

/* Floating animation for cards */
@keyframes float{
  0%,100%{transform:translateY(0px)}
  50%{transform:translateY(-8px)}
}
.float-animation{animation:float 6s ease-in-out infinite}

/* Glow pulse for critical elements */
@keyframes glowPulse{
  0%,100%{box-shadow:0 0 20px rgba(255,45,85,.4), 0 0 40px rgba(255,45,85,.2)}
  50%{box-shadow:0 0 40px rgba(255,45,85,.8), 0 0 60px rgba(255,45,85,.4)}
}
.glow-pulse{animation:glowPulse 2s ease-in-out infinite}

/* Gradient border animation */
@keyframes gradientBorder{
  0%{background-position:0% 50%}
  50%{background-position:100% 50%}
  100%{background-position:0% 50%}
}
.gradient-border{
  border:2px solid transparent;
  background:linear-gradient(var(--panel),var(--panel)) padding-box,
             linear-gradient(90deg, var(--red), var(--purple), var(--cyan), var(--red)) border-box;
  background-size:300% 300%;
  animation:gradientBorder 4s ease infinite;
}

/* Shimmer effect enhancement */
@keyframes shimmerEnhanced{
  0%{background-position:200% 50%}
  100%{background-position:-200% 50%}
}
.shimmer-enhanced{
  background:linear-gradient(90deg,
    rgba(14,16,24,.5),
    rgba(255,45,85,.15),
    rgba(187,134,252,.15),
    rgba(0,229,255,.15),
    rgba(14,16,24,.5));
  background-size:400% 100%;
  animation:shimmerEnhanced 3s ease-in-out infinite;
}

/* 3D flip card effect */
.flip-card{
  perspective:1000px;
  transition:transform 0.6s;
  transform-style:preserve-3d;
}
.flip-card:hover{
  transform:rotateY(180deg);
}

/* Neon text glow */
.neon-text{
  color:var(--red);
  text-shadow:
    0 0 10px rgba(255,45,85,.8),
    0 0 20px rgba(255,45,85,.6),
    0 0 30px rgba(255,45,85,.4),
    0 0 40px rgba(255,45,85,.2);
  animation:neonFlicker 3s ease-in-out infinite alternate;
}
@keyframes neonFlicker{
  0%,100%{opacity:1}
  50%{opacity:0.8}
}

/* Glassmorphism effect */
.glass{
  background:rgba(14,16,24,.4);
  backdrop-filter:blur(20px) saturate(180%);
  border:1px solid rgba(255,255,255,.1);
  box-shadow:0 8px 32px rgba(0,0,0,.2);
}

/* Scale on hover with bounce */
.scale-bounce:hover{
  animation:scaleBounce 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
}
@keyframes scaleBounce{
  0%{transform:scale(1)}
  50%{transform:scale(1.1)}
  75%{transform:scale(0.95)}
  100%{transform:scale(1.05)}
}

/* Particle effect background */
@keyframes particleFloat{
  0%{transform:translateY(0) translateX(0) rotate(0deg);opacity:0}
  10%{opacity:1}
  90%{opacity:1}
  100%{transform:translateY(-100vh) translateX(20px) rotate(360deg);opacity:0}
}
.particle{
  position:absolute;
  width:4px;height:4px;
  background:var(--red);
  border-radius:50%;
  opacity:0.5;
  pointer-events:none;
}

/* Rainbow gradient text */
.rainbow-text{
  background:linear-gradient(90deg,
    var(--red), var(--orange), var(--gold),
    var(--accent), var(--blue), var(--purple), var(--pink));
  background-size:200% 100%;
  -webkit-background-clip:text;
  background-clip:text;
  -webkit-text-fill-color:transparent;
  animation:rainbowShift 6s linear infinite;
}
@keyframes rainbowShift{
  0%{background-position:0% 50%}
  100%{background-position:200% 50%}
}

/* Heartbeat animation for emergency indicators */
@keyframes heartbeat{
  0%,100%{transform:scale(1)}
  10%{transform:scale(1.1)}
  20%{transform:scale(1)}
  30%{transform:scale(1.1)}
  40%{transform:scale(1)}
}
.heartbeat{animation:heartbeat 1.5s ease-in-out infinite}
