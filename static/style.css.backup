*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}

:root{
  --bg:       #07080f;
  --panel:    #0e1018;
  --panel2:   #090b12;
  --border:   #1c2030;
  --red:      #ff2d55;
  --red-d:    rgba(255,45,85,.12);
  --red-glow: rgba(255,45,85,.25);
  --accent:   #00e676;
  --accent-d: rgba(0,230,118,.1);
  --blue:     #2979ff;
  --blue-d:   rgba(41,121,255,.12);
  --gold:     #ffd740;
  --gold-d:   rgba(255,215,64,.1);
  --purple:   #bb86fc;
  --purple-d: rgba(187,134,252,.12);
  --cyan:     #00e5ff;
  --cyan-d:   rgba(0,229,255,.12);
  --orange:   #ff6f00;
  --orange-d: rgba(255,111,0,.12);
  --pink:     #ff4081;
  --pink-d:   rgba(255,64,129,.12);
  --text:     #e8eaf6;
  --muted:    #4a5568;
  --font:     'Nunito', sans-serif;
  --mono:     'JetBrains Mono', monospace;
  --display:  'Rajdhani', sans-serif;
}

html{scroll-behavior:smooth}
body{
  background:linear-gradient(135deg, #07080f 0%, #0a0d1a 50%, #0d0520 100%);
  color:var(--text);font-family:var(--font);min-height:100vh;overflow-x:hidden;
  position:relative;
}

/* BG with animated gradient overlay */
.bg-pulse{
  position:fixed;inset:0;pointer-events:none;z-index:0;
  background:radial-gradient(ellipse 60% 40% at 50% 0%, rgba(255,45,85,.08) 0%, transparent 40%),
             radial-gradient(circle at 80% 80%, rgba(187,134,252,.06) 0%, transparent 50%),
             radial-gradient(circle at 20% 70%, rgba(0,229,255,.05) 0%, transparent 50%);
  animation:blinear-gradient(90deg, #12040a, #1a0510, #12040a);
  background-size:200% 100%;
  border-bottom:2px solid rgba(255,45,85,.4);
  overflow:hidden;height:32px;
  box-shadow:0 4px 20px rgba(255,45,85,.15);
  animation:tickerGlow 3s ease-in-out infinite;
}
@keyframes tickerGlow{
  0%,100%{border-bottom-color:rgba(255,45,85,.4)}
  50%{border-bottom-color:rgba(187,134,252,.4)}
}
.ticker-label{
  background:linear-gradient(135deg, var(--red), var(--pink));
  color:#fff;
  font-family:var(--display);font-weight:700;font-size:12px;
  padding:0 14px;height:100%;display:flex;align-items:center;
  white-space:nowrap;flex-shrink:0;letter-spacing:1px;
  box-shadow:0 0 20px rgba(255,45,85,.4);
  animation:labelPulse 2s ease-in-out infinite;
}
@keyframes labelPulse{
  0%,100%{box-shadow:0 0 20px rgba(255,45,85,.4)}
  50%{box-shadow:0 0 30px rgba(255,64,129,.6)}
/* ── TICKER ─────────────────────────────────────────── */
.ticker-bar{
  position:sticky;top:0;z-index:200;
  display:flex;align-items:center;gap:0;
  background:#12040a;border-bottom:1px solid rgba(255,45,85,.3);
  overflow:hidden;height:32px;
}
.ticker-label{
  background:var(--red);color:#fff;
  font-family:var(--display);font-weight:700;font-size:12px;
  padding:0 14px;height:100%;display:flex;align-items:center;
  white-space:nowrap;flex-85);
  backdrop-filter:blur(30px) saturate(180%);
  border-bottom:1px solid var(--border);
  box-shadow:0 8px 32px rgba(0,0,0,.3);
  transition:all 0.3s ease;
}
header:hover{
  background:rgba(14,16,24,.9);
  box-shadow:0 12px 40px rgba(255,45,85,.1eight:100%;display:flex;align-items:center}
.ticker-content{
  white-space:nowrap;font-size:12px;color:var(--text);
  animation:tickerScroll 40s linear infinite;
  padding-left:100%;
}
@keyframes tickerScroll{0%{transform:translateX(0)}100%{transform:translateX(-100%)}}

/* ── HEADER ─────────────────────────────────────────── */
header{
  position:sticky;top:32px;z-index:100;
  display:flex;align-items:center;justify-content:space-between;
  padding:0 28px;height:62px;
  background:rgba(7,8,15,.92);
  backdrop-filte10px;color:var(--muted);
  font-family:var(--font);font-size:12px;font-weight:600;
  padding:7px 14px;cursor:pointer;
  transition:all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  white-space:nowrap;position:relative;overflow:hidden;
}
.tab::before{
  content:'';position:absolute;inset:0;
  background:radial-gradient(circle at center, rgba(255,45,85,.15), transparent);
  opacity:0;transition:opacity 0.3s ease;z-index:-1;
}
.tab:hover{
  color:var(--text);border-color:var(--border);
  transform:translateY(-2px) scale(1.02);
  box-shadow:0 4px 12px rgba(255,45,85,.15);
}
.tab:hover::before{opacity:1}
.tab.active{
  background:linear-gradient(135deg, var(--red-d), var(--purple-d));
  border-color:rgba(255,45,85,.5);color:var(--red);
  box-shadow:0 4px 20px rgba(255,45,85,.25), inset 0 1px 0 rgba(255,255,255,.1);
  transform:translateY(-1px);

.heartbeat-svg polyline{
  stroke-dasharray:200;stroke-dashoffset:200;
  animation:drawLine 2s ease forwards, heartPulse 2s 2s ease-in-out infinite;
}
@keyframes drawLine{to{stroke-dashoffset:0}}
@keyframes heartPulse{0%,100%{opacity:1}50%{opacity:.4}}

.logo-text{
  font-family:var(--display);font-size:22px;font-weight:700;
  letter-spacing:1px;line-height:1;
  transition:all 0.3s ease;
}
.logo-text span{
  background:linear-gradient(90deg, var(--red), var(--pink), var(--purple));
  background-size:200% 100%;
  -webkit-background-clip:text;
  background-clip:text;
  -webkit-text-fill-color:transparent;
  animation:logoShift 4s ease-in-out infinite;
  display:inline-block;
  text-shadow:0 0 20px rgba(255,45,85,.5);
}
@keyframes logoShift{
  0%,100%{background-position:0% 50%}
  50%{background-position:100% 50%}
}
header:hover .logo-text span{
  animation:logoShift 1s ease-in-out infinite;
}
.logo-sub{font-size:10px;color:var(--muted);margin-top:2px;letter-spacing:.5px}
linear-gradient(135deg, rgba(14,16,24,.95), rgba(18,20,30,.95));
  border:1px solid var(--border);
  border-radius:20px;padding:24px;margin-bottom:4px;
  transition:all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  position:relative;overflow:hidden;
  backdrop-filter:blur(10px);
  box-shadow:0 8px 32px rgba(0,0,0,.2);
}
.panel::before{
  content:'';position:absolute;top:0;left:0;right:0;height:1px;
  background:linear-gradient(90deg, transparent, rgba(255,45,85,.3), transparent);
  opacity:0;transition:opacity 0.4s ease;
}
.panel:hover{6px;margin-bottom:24px}
.stat-card{
  background:linear-gradient(135deg, rgba(14,16,24,.9), rgba(18,20,30,.9));
  border:1px solid var(--border);
  border-radius:18px;padding:20px;
  transition:all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  position:relative;overflow:hidden;
  backdrop-filter:blur(10px);
  box-shadow:0 4px 24px rgba(0,0,0,.15);
}
.stat-card::after{
  content:'';position:absolute;top:0;left:0;right:0;bottom:0;
  background:radial-gradient(circle at 50% 0%, rgba(255,45,85,.08), transparent);
  opacity:0;transition:opacity 0.4s ease;pointer-events:none;
}
.stat-card:hover{
  transfor
  font-family:var(--mono);font-size:38px;font-weight:700;line-height:1;margin-bottom:4px;
  color:var(--red);
  text-shadow:0 0 30px rgba(255,45,85,.6), 0 0 10px rgba(255,45,85,.4);
  animation:valueGlow 3s ease-in-out infinite;
}
@keyframes valueGlow{
  0%,100%{text-shadow:0 0 30px rgba(255,45,85,.6), 0 0 10px rgba(255,45,85,.4)}
  50%{text-shadow:0 0 40px rgba(255,45,85,.8), 0 0 20px rgba(255,45,85,.6)}
}
.stat-val.accent{
  color:var(--accent);
  text-shadowlinear-gradient(135deg, rgba(14,16,24,.9), rgba(18,20,30,.9));
  border:1px solid var(--border);
  border-radius:16px;padding:16px 12px;text-align:center;
  transition:all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  cursor:pointer;position:relative;overflow:hidden;
  backdrop-filter:blur(10px);
  box-shadow:0 4px 20px rgba(0,0,0,.15);
}
.gauge-card::before{
  content:'';position:absolute;inset:-2px;
  background:conic-gradient(from 0deg, var(--red), var(--purple), var(--cyan), var(--red));
  border-radius:16px;opacity:0;
  transition:opacity 0.4s ease;z-index:-1;
  animation:rotateBorder 4s linear infinite;
}
@keyframes rotateBorder{
  0%{transform:rotate(0deg)}
  100%{transform:rotate(360deg)}
}
.gauge-card:hover{
  transform:translateY(-6px) scale(1.05) rotateY(5deg);
  border-color:rgba(255,45,85,.6);
  box-shadow:0 12px 40px rgba(255,45,85,.35),
             0 0 60px rgba(187,134,252,.2);
}
.gauge-card:hover::before{opacity:0.3
}
.stat-val.gold{
  color:var(--gold);
  text-shadow:0 0 30px rgba(255,215,64,.6), 0 0 10px rgba(255,215,64,.4);

}rgba(9,11,18,.95);border:1px solid var(--border);
  border-radius:12px;padding:12px 16px;
  color:var(--text);font-family:var(--font);font-size:13px;
  outline:none;
  transition:all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  width:100%;position:relative;
  box-shadow:inset 0 2px 8px rgba(0,0,0,.2);
}
.inp:hover{
  border-color:rgba(255,45,85,.3);
  background:rgba(14,16,24,.95);
}ff4081,#c8001a);
  background-size:200% 200%;
  border:none;border-radius:14px;color:#fff;
  font-family:var(--font);font-size:14px;font-weight:700;
  padding:14px 24px;cursor:pointer;width:100%;
  transition:all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow:0 8px 30px rgba(255,45,85,.4),
             0 0 0 1px rgba(255,255,255,.1) inset;
  position:relative;overflow:hidden;
  text-transform:uppercase;letter-spacing:1px;
}
.btn-danger::before{
  content:'';position:absolute;inset:0;
  background:linear-gradient(135deg, rgba(255,255,255,.2), transparent);
  opacity:0;transition:opacity 0.3s ease;
}
.btn-danger:hover{
  transform:translateY(-3px) scale(1.02);
  box-shadow:0 12px 48px rgba(255,45,85,.6),
             0 0 60px rgba(255,64,129,.4);
  background-position:100% 100%;
  animation:btnPulse 1.5s ease-in-out infinite;
}
.btn-danger:hover::before{opacity:1}
@keyframes btnPulse{
  0%,100%{box-shadow:0 12px 48px rgba(255,45,85,.6)}
  50%{box-shadow:0 12px 60px rgba(255,64,129,.8)}
}
.btn-danger:active{transform:translateY(-1px)00e5ff,#1a56d6);
  background-size:200% 200%;
  border:none;border-radius:14px;color:#fff;
  font-family:var(--font);font-size:14px;font-weight:700;
  padding:14px 24px;cursor:pointer;
  transition:all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow:0 8px 30px rgba(41,121,255,.4),
             0 0 0 1px rgba(255,255,255,.1) inset;
  position:relative;overflow:hidden;
  text-transform:uppercase;letter-spacing:1px;
}
.btn-primary::before{
  content:'';position:absolute;inset:0;
  background:linear-gradient(135deg, rgba(255,255,255,.2), transparent);
  opacity:0;transition:opacity 0.3s ease;
}
.btn-primary:hover{
  transform:translateY(-3px) scale(1.02);
  box-shadow:0 12px 48px rgba(41,121,255,.6),
             0 0 60px rgba(0,229,255,.4);
  background-position:100% 100%;
}
.btn-primary:hover::before{opacity:1}
.btn-primary:active{transform:translateY(-1px) scale(0.9855,45,85,.4);color:var(--red)}

/* ── CONTENT ─────────────────────────────────────────── */
.tab-content{display:none;position:relative;z-index:1}
.tab-conte4px 12px;border-radius:20px;letter-spacing:.8px;
  font-family:var(--display);
  transition:all 0.3s ease;
  box-shadow:0 2px 8px rgba(0,0,0,.2);
  animation:badgeFloat 3s ease-in-out infinite;
}
@keyframes badgeFloat{
  0%,100%{transform:translateY(0)}
  50%{transform:translateY(-2px)}
}
.badge.critical{
  background:linear-gradient(135deg, rgba(255,45,85,.25), rgba(255,64,129,.25));
  color:var(--red);border:1px solid rgba(255,45,85,.5);
  box-shadow:0 0 20px rgba(255,45,85,.3);
}
.badge.urgent{
  background:linear-gradient(135deg, rgba(255,160,0,.25), rgba(255,111,0,.25));
  color:#ffa000
  padding:12px 14px;border-bottom:1px solid rgba(28,32,48,.5);
  transition:all 0.3s ease;
}
.data-table tr{transition:all 0.3s cubic-bezier(0.4, 0, 0.2, 1)}
.data-table tr:hover{
  transform:scale(1.01);
}
.data-table tr:hover td{
  background:linear-gradient(90deg, rgba(255,45,85,.08), rgba(187,134,252,.06), rgba(255,45,85,.08));
  box-shadow:0 2px 12px rgba(255,45,85,.15);

}
.badge.routine{
  background:linear-gradient(135deg, rgba(0,230,118,.2), rgba(0,229,255,.2));
  color:var(--accent);border:1px solid rgba(0,230,118,.4);
  box-shadow:0 0 20px rgba(0,230,118,.3);
}
.badge.pending{
  background:linear-gradient(135deg, rgba(41,121,255,.2), rgba(187,134,252,.2));
  color:var(--blue);border:1px solid rgba(41,121,255,.5);
  box-shadow:0 0 20px rgba(41,121,255,.3);
}
.badge.allocated{
  background:linear-gradient(135deg, rgba(0,230,118,.2), rgba(0,229,255,.2));
  color:var(--accent);
  box-shadow:0 0 20px rgba(0,230,118,.3);
}
.badge.fulfilled{
  background:rgba(100,100,100,.25);color:var(--muted);
  border:1px solid rgba(100,100,100,.4);

  background:var(--panel);border:1px solid var(--border);
  border-radius:16px;padding:20px;margin-bottom:4px;
  transition:border-color .2s;
}
.panel:hover{border-color:rgba(255,45,85,.2)}
.panel-title{font-family:var(--display);font-size:17px;font-weight:700;margin-bottom:16px;letter-spacing:.5px}
.panel-sub{font-size:11px;color:var(--muted);margin-top:2px}
.section-title{
  font-family:var(--display);font-size:20px;font-weight:700;
  letter-spacing:.8px;margin:20px 0 12px;
  background:linear-gradient(90deg, var(--text), var(--purple), var(--cyan));
  background-size:200% 100%;
  -webkit-background-clip:text;
  background-clip:text;
  -webkit-text-fill-color:transparent;
  animation:titleShift 8s ease-in-out infinite;
  position:relative;
  display:inline-block;
}
@keyframes titleShift{
  0%,100%{background-position:0% 50%}
  50%{background-position:100% 50%}
}
.section-title::after{
  content:'';position:absolute;bottom:-4px;left:0;right:0;height:2px;
  background:linear-gradient(90deg, transparent, var(--red), transparent);
  opacity:0.5;
}

/* ── STAT CARDS ──────────────────────────────────────── */
.stat-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:24px}
.stat-card{
  background:var(--panel);border:1px solid var(--border);
  border-radius:14px;padding:18px;
  transition:transform .2s,border-color .2s;
}
.stat-card:hover{transform:translateY(-3px)}
.stat-card.critical{border-color:rgba(255,45,85,.3);background:linear-gradient(135deg,#0e1018,#12050a)}
.stat-top{display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;font-size:16px}
.stat-label{font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:1.2px;font-weight:700}
.stat-val{font-family:var(--mono);font-size:34px;font-weight:700;line-height:1;margin-bottom:4px;color:var(--red)}
.stat-val.accent{color:var(--accent);text-shadow:0 0 20px rgba(0,230,118,.3)}
.stat-val.blue{color:var(--blue);text-shadow:0 0 20px rgba(41,121,255,.3)}
.stat-val.gold{color:var(--gold);text-shadow:0 0 20px rgba(255,215,64,.3)}
.stat-sub{font-size:11px;color:var(--muted)}

/* ── BLOOD GAUGES ────────────────────────────────────── */
.gauge-grid{
  display:grid;grid-template-columns:repeat(8,1fr);
  gap:12px;margin-bottom:24px;
}
.gauge-card{
  background:var(--panel);border:1px solid var(--border);
  border-radius:14px;padding:14px 10px;text-align:center;
  transition:transform .2s,border-color .2s;cursor:default;
}
.gauge-card:hover{transform:translateY(-4px);border-color:rgba(255,45,85,.3)}
.gauge-blood-type{
  font-family:var(--mono);font-size:20px;font-weight:700;
  background:linear-gradient(135deg, var(--red), var(--pink), var(--purple));
  background-size:200% 100%;
  -webkit-background-clip:text;
  background-clip:text;
  -webkit-text-fill-color:transparent;
  margin-bottom:8px;
  animation:bloodTypeShift 5s ease-in-out infinite;
  text-shadow:0 0 20px rgba(255,45,85,.5);
}
@keyframes bloodTypeShift{
  0%,100%{background-position:0% 50%;filter:hue-rotate(0deg)}
  50%{background-position:100% 50%;filter:hue-rotate(20deg)}
}
.gauge-card:hover .gauge-blood-type{
  animation:bloodTypeShift 1.5s ease-in-out infinite;
}
.gauge-ring-wrap{position:relative;width:72px;height:72px;margin:0 auto 8px}
.gauge-ring-wrap canvas{position:absolute;top:0;left:0}
.gauge-center{
  position:absolute;inset:0;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
}
.gauge-units{font-family:var(--mono);font-size:14px;font-weight:700;line-height:1}
.gauge-label-text{font-size:9px;color:var(--muted);margin-top:1px}
.gauge-status{
  font-size:9px;font-weight:700;letter-spacing:.5px;
  padding:2px 8px;border-radius:10px;display:inline-block;
}
.gauge-status.critical{background:rgba(255,45,85,.2);color:var(--red)}
.gauge-status.low{background:rgba(255,160,0,.2);color:#ffa000}
.gauge-status.ok{background:rgba(0,230,118,.15);color:var(--accent)}

/* ── FORM ────────────────────────────────────────────── */
.two-col{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:20px}
.form-group{display:flex;flex-direction:column;gap:5px;margin-bottom:12px}
.form-group label{font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:.8px;font-weight:700}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.inp{
  background:var(--panel2);border:1px solid var(--border);
  border-radius:10px;padding:10px 14px;
  color:var(--text);font-family:var(--font);font-size:13px;
  outline:none;transition:border-color .2s;width:100%;
}
.inp:focus{border-color:var(--red)}
.inp::placeholder{color:var(--muted)}
select.inp option{background:var(--panel2)}

/* ── BUTTONS ─────────────────────────────────────────── */
.btn-danger{
  background:linear-gradient(135deg,#ff2d55,#c8001a);
  border:none;border-radius:10px;color:#fff;
  font-family:var(--font);font-size:13px;font-weight:700;
  padding:11px 22px;cursor:pointer;width:100%;
  transition:opacity .2s,transform .2s;
  box-shadow:0 4px 20px rgba(255,45,85,.3);
}
.btn-danger:hover{opacity:.9;transform:translateY(-1px)}
.btn-danger:disabled{opacity:.5;cursor:not-allowed;transform:none}

.btn-primary{
  background:linear-gradient(135deg,#2979ff,#1a56d6);
  border:none;border-radius:10px;color:#fff;
  font-family:var(--font);font-size:13px;font-weight:700;
  padding:11px 22px;cursor:pointer;
  transition:opacity .2s,transform .2s;
  box-shadow:0 4px 20px rgba(41,121,255,.3);
}
.btn-primary:hover{opacity:.9;transform:translateY(-1px)}

/* ── URGENCY BADGES ──────────────────────────────────── */
.badge{
  display:inline-block;font-size:10px;font-weight:700;
  padding:3px 10px;border-radius:20px;letter-spacing:.5px;
  font-family:var(--display);
}
.badge.critical{background:rgba(255,45,85,.2);color:var(--red);border:1px solid rgba(255,45,85,.3)}
.badge.urgent{background:rgba(255,160,0,.2);color:#ffa000;border:1px solid rgba(255,160,0,.3)}
.badge.routine{background:rgba(0,230,118,.15);color:var(--accent);border:1px solid rgba(0,230,118,.2)}
.badge.pending{background:rgba(41,121,255,.15);color:var(--blue);border:1px solid rgba(41,121,255,.3)}
.badge.allocated{background:rgba(0,230,118,.15);color:var(--accent)}
.badge.fulfilled{background:rgba(100,100,100,.2);color:var(--muted)}

/* ── TABLE ───────────────────────────────────────────── */
.data-table{width:100%;border-collapse:collapse;font-size:12px}
.data-table th{
  text-align:left;color:var(--muted);
  font-size:10px;text-transform:uppercase;letter-spacing:1px;font-weight:700;
  padding:8px 12px;border-bottom:1px solid var(--border);
}
.data-table td{padding:10px 12px;border-bottom:1px solid rgba(28,32,48,.5)}
.data-table tr:hover td{background:rgba(255,45,85,.04)}
.data-table tr:last-child td{border-bottom:none}

/* ── AI RESULT ───────────────────────────────────────── */
.ai-result{animation:fadeUp .4s ease}
.urgency-banner{
  border-radius:12px;padding:16px;margin-bottom:14px;
  border:1px solid;
}
.urgency-banner.critical{background:rgba(255,45,85,.1);border-color:rgba(255,45,85,.4)}
.urgency-banner.urgent{background:rgba(255,160,0,.1);border-color:rgba(255,160,0,.4)}
.urgency-banner.routine{background:rgba(0,230,118,.08);border-color:rgba(0,230,118,.3)}
.urgency-title{font-family:var(--display);font-size:20px;font-weight:700;margin-bottom:6px}
.ai-rec-box{
  background:var(--panel2);border:1px solid var(--border);
  border-radius:10px;padding:14px;font-size:12px;line-height:1.7;color:var(--text);
}
.ai-placeholder{
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  gap:12px;padding:40px 20px;color:var(--muted);font-size:13px;text-align:center;
}

/* ── MAP ─────────────────────────────────────────────── */
.map-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px}
.map-legend{display:flex;gap:16px;align-items:center}
.leg{display:flex;align-items:center;gap:6px;font-size:11px;color:var(--muted)}
.leg-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0}
.leg-dot.red{background:var(--red)}
.leg-dot.blue{background:var(--blue)}
.leg-dot.green{background:var(--accent)}
.leg-dot.grey{background:var(--muted)}
.map-wrap{
  height:520px;border-radius:20px;overflow:hidden;
  border:2px solid var(--border);
  box-shadow:0 12px 48px rgba(0,0,0,.3),
             0 0 0 1px rgba(255,45,85,.1);
  transition:all 0.4s ease;
  position:relative;
}
.map-wrap::before{
  content:'';position:absolute;inset:0;
  background:linear-gradient(135deg, rgba(255,45,85,.05), rgba(187,134,252,.05));
  opacity:0;transition:opacity 0.4s ease;
  pointer-events:none;z-index:1000;
}
.map-wrap:hover{
  border-color:rgba(255,45,85,.4);
  box-shadow:0 16px 60px rgba(255,45,85,.3),
             0 0 60px rgba(187,134,252,.2);
}
.map-wrap:hover::before{opacity:1}
.leaflet-container{background:#0d1117!important}

/* ── AI CHAT ─────────────────────────────────────────── */
.chat-page{display:flex;flex-direction:column;align-items:center}
.chat-panel{width:100%;max-width:760px}
.chat-header{display:flex;align-items:center;gap:14px;margin-bottom:0;padding-bottom:16px;border-bottom:1px solid var(--border)}
.chat-avatar{
  width:48px;height:48px;border-radius:16px;flex-shrink:0;
  background:linear-gradient(135deg, var(--red-d), var(--purple-d));
  border:2px solid rgba(255,45,85,.4);
  display:flex;align-items:center;justify-content:center;font-size:24px;
  box-shadow:0 0 30px rgba(255,45,85,.4),
             inset 0 2px 10px rgba(255,255,255,.1);
  animation:avatarPulse 3s ease-in-out infinite;
  transition:all 0.3s ease;
}
@keyframes avatarPulse{
  0%,100%{box-shadow:0 0 30px rgba(255,45,85,.4), inset 0 2px 10px rgba(255,255,255,.1)}
  50%{box-shadow:0 0 50px rgba(187,134,252,.6), inset 0 2px 10px rgba(255,255,255,.2)}
}
.chat-avatar:hover{
  transform:scale(1.1) rotate(5deg);
}
.online-dot{
  width:10px;height:10px;border-radius:50%;background:var(--accent);
  margin-left:auto;flex-shrink:0;
  box-shadow:0 0 8px var(--accent);
  animation:pulse-online 2s ease-in-out infinite;
}
@keyframes pulse-online{0%,100%{opacity:1}50%{opacity:.4}}
.chat-messages{
  min-height:480px;max-height:560px;overflow-y:auto;
  display:flex;flex-direction:column;gap:12px;
  padding:16px 0;scroll-behavior:smooth;
}
.chat-messages::-webkit-scrollbar{width:4px}
.chat-messages::-webkit-scrollbar-thumb{background:var(--border);border-radius:4px}
.chat-bubble{
  max-width:85%;padding:14px 18px;border-radius:18px;
  font-size:13.5px;line-height:1.75;
  animation:bubblePop 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
  word-wrap:break-word;word-break:break-word;white-space:normal;
  position:relative;
  box-shadow:0 4px 20px rgba(0,0,0,.15);
  transition:all 0.3s ease;
}
@keyframes bubblePop{
  0%{opacity:0;transform:scale(0.8) translateY(10px)}
  100%{opacity:1;transform:scale(1) translateY(0)}
}
.chat-bubble:hover{
  transform:translateY(-2px);
  box-shadow:0 8px 30px rgba(0,0,0,.25);
}
.chat-bubble.user{
  align-self:flex-end;
  background:linear-gradient(135deg, rgba(255,45,85,.15), rgba(255,64,129,.15));
  color:var(-linear-gradient(135deg, rgba(14,16,24,.9), rgba(18,20,30,.9));
  border:1px solid var(--border);
  border-radius:24px;color:var(--muted);
  font-family:var(--font);font-size:11px;padding:6px 14px;cursor:pointer;
  transition:all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  box-shadow:0 2px 10px rgba(0,0,0,.15);
  position:relative;overflow:hidden;
}
.suggestion::before{
  content:'';position:absolute;inset:0;
  background:radial-gradient(circle at center, rgba(255,45,85,.15), transparent);
  opacity:0;transition:opacity 0.3s ease;
}
.suggestion:hover{
  border-color:var(--red);color:var(--red);
  transform:translateY(-2px) scale(1.05);
  box-shadow:0 6px 20px rgba(255,45,85,.3);
}
.suggestion:hover::before{opacity:1
}
.chat-bubble.ai{
  align-self:flex-start;
  background:linear-gradient(135deg, rgba(14,16,24,.95), rgba(18,20,30,.95));
  color:var(--text);
  border:1px solid var(--border);
  backdrop-filter:blur(10px);
}
.chat-bubble.typing{opacity:.5}
.chat-suggestions{
  display:flex;flex-wrap:wrap;gap:8px;margin-top:4px;align-self:flex-start;
}
.suggestion{
  background:var(--panel2);border:1px solid var(--border);
  border-radius:20px;color:var(--muted);
  font-family:var(--font);font-size:11px;padding:5px 12px;cursor:pointer;
  transition:all .2s;
}
.suggestion:hover{border-color:var(--red);color:var(--red)}
.chat-input-row{display:flex;gap:10px;margin-top:14px;padding-top:14px;border-top:1px solid var(--border)}
.chat-inp{
  flex:1;background:var(--panel2);border:1px solid var(--border);
  border-radius:12px;padding:11px 16px;
  color:var(--text);font-family:var(--font);font-size:13px;outline:none;
  transition:border-color .2s;
}
.chat-inp:focus{border-color:var(--red)}
.chat-inp::placeholder{color:var(--muted)}
.chat-send{linear-gradient(135deg, rgba(14,16,24,.9), rgba(18,20,30,.9));
  border:1px solid var(--border);
  border-radius:18px;padding:18px;
  transition:all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  animation:fadeUp .4s ease both;
  position:relative;overflow:hidden;
  backdrop-filter:blur(10px);
  box-shadow:0 4px 24px rgba(0,0,0,.15);
}
.pred-card::after{
  content:'';position:absolute;top:0;left:0;right:0;bottom:0;
  background:radial-gradient(circle at 50% 0%, rgba(255,45,85,.05), transparent);
  opacity:0;transition:opacity 0.4s ease;pointer-events:none;
}
.pred-card:hover{
  transform:translateY(-6px) scale(1.03) rotateX(3deg);
  box-shadow:0 16px 50px rgba(0,0,0,.3);
}
.pred-card:hover::after{opacity:1}
.pred-card.critical{
  border-color:rgba(255,45,85,.5);
  background:linear-gradient(135deg,rgb2px;
  background:linear-gradient(135deg, rgba(14,16,24,.9), rgba(18,20,30,.9));
  border:1px solid var(--border);
  border-radius:14px;padding:12px 14px;
  transition:all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  box-sh40px;height:40px;border-radius:12px;
  background:linear-gradient(135deg, var(--red-d), var(--purple-d));
  border:2px solid rgba(255,45,85,.3);
  display:flex;align-items:center;justify-content:center;
  font-family:var(--mono);font-size:13px;font-weight:700;
  color:var(--red);flex-shrink:0;
  box-shadow:0 4px 16px rgba(255,45,85,.25),
             inset 0 1px 4px rgba(255,255,255,.1);
